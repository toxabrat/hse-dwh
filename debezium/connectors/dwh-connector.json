{
  "name" : "dwh-sink-connector",
  "config" : {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "tasks.max": "1",

    "topics.regex": "(logistics-service|user-service|order-service)\\..*",

    "connection.url": "jdbc:postgresql://postgres-dwh:5432/dwh_db",
    "connection.user": "postgres",
    "connection.password": "postgres",
    "dialect.name": "PostgreSqlDatabaseDialect",

    "table.name.format": "raw_data.${topic}",

    "auto.create": "true",
    "auto.evolve": "true",
    "insert.mode": "insert",
    "pk.mode": "none",

    "transforms": "unwrap, route",

    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "rewrite",

    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "(logistics-service|user-service|order-service)\\.(.*)\\.(.*)",
    "transforms.route.replacement": "$3"
  }
}