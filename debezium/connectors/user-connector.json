{
  "name": "user-service-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "plugin.name": "pgoutput",
    "database.hostname": "postgres-user-replica",
    "database.port": "5432",
    "database.user": "postgres",
    "database.password": "postgres",
    "database.dbname": "user_service_db",
    "topic.prefix": "user-service",
    "table.include.list": "user_service_db.users,user_service_db.user_status_history,user_service_db.user_addresses",
    "snapshot.mode": "initial",
    "heartbeat.interval.ms": "5000",
    "slot.name": "user_service_debezium",
    "publication.name": "user_service_publication",
    "topic.creation.default.cleanup.policy": "delete",
    "topic.creation.default.partitions": "1",
    "topic.creation.default.replication.factor": "1",
    "topic.creation.default.retention.ms": "604800000",
    "topic.creation.enable": "true"
  }
}
